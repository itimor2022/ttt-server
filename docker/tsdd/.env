# 容器名称
CONTAINER_NAME=pop
EXTERNAL_IP=43.199.60.109

######### Tsdd相关的配置 #########
# mysql
MYSQL_DATABASE=im
MYSQL_ROOT_PASSWORD=Aa1234567
# redis
TS_DB_REDISADDR=redis:6379
# minio
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=Aa1234567
MINIO_SERVER_URL=http://43.199.60.109:9000
MINIO_BROWSER_REDIRECT_URL=http://43.199.60.109:9001

######### WuKongIM相关的配置 #########
# 模式 debug or release
WK_MODE=release
# 业务服务的grpc地址
WK_WEBHOOK_GRPCADDR=172.17.0.1:6979
# 业务服务的数据源地址
WK_DATASOURCE_ADDR=http://172.17.0.1:8090/v1/datasource
# 开启频道信息同步
WK_DATASOURCE_CHANNELINFOON=true
# 是否关闭个人白名单功能，默认是开启的，如果关闭发送消息将不做好友关系的判断
WK_WHITELISTOFFOFPERSON=false
# 监控内网地址
WK_TRACE_PROMETHEUSAPIURL=http://172.17.0.1:9090